pipeline {
    agent any
    
    stages {
        stage('Update Package') {
            steps {
                sh 'sudo apt-get update -y'
            }
        stage('Install Nginx') {
            steps {
                sh 'sudo apt-get install nginx -y'
            }
        stage('Start Nginx') {
            steps {
                sh 'sudo systemctl start nginx'
                sh 'sudo systemctl enable nginx' 
            }
        stage('Verify') {
            steps {
                sh 'sudo systemctl status nginx'
                sh 'curl -I localhost' 
            }
        }
    }
    
    post {
        success {
            echo 'Nginx install ho gaya aur chal raha hai'
        }
        failure {
            echo 'Kahin error aaya. Jenkins user ko sudo access hai ya nahi check kar'
        }
    }
}
